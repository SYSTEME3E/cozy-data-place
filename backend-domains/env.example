# ═══════════════════════════════════════════════════════════
# NEXORA Domain API — Variables d'environnement
# Copier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════

# ── Supabase (OBLIGATOIRE)
SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...  # Settings > API > service_role (JAMAIS exposé)

# ── Réseau (OBLIGATOIRE)
PORT=3001
APP_HOSTNAME=app.nexora.com        # Votre domaine principal Nexora
SERVER_IP=1.2.3.4                  # IP de votre serveur (pour A records)
NEXORA_DOMAIN=nexora.com           # Domaine racine Nexora

# ── Frontend (CORS)
FRONTEND_URL=https://app.nexora.com,https://nexora.com

# ── Cloudflare For SaaS (OPTIONNEL — pour SSL automatique)
CLOUDFLARE_API_TOKEN=              # Profile > API Tokens > Create Token
CLOUDFLARE_ZONE_ID=                # Overview de votre zone Cloudflare

# ── Limites
MAX_DOMAINS_PER_USER=10
